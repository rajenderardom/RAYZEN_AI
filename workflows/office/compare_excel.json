{
    "name": "Web Excel Comparison Portal",
    "version": "1.0",
    "description": "Uploads two Excel workbooks to a web-based comparison tool and downloads the compared output.",
    "steps": [
        {
            "action": "open_url",
            "url": "https://example.com/excel-tools/compare"
        },
        {
            "action": "wait_for_selector",
            "selector": "#file-old"
        },
        {
            "action": "upload",
            "selector": "#file-old",
            "path": "data/old.xlsx"
        },
        {
            "action": "upload",
            "selector": "#file-new",
            "path": "data/new.xlsx"
        },
        {
            "action": "click",
            "selector": "#compare-btn"
        },
        {
            "action": "download",
            "selector": "#download-report",
            "path": "data/report.xlsx"
        }
    ]
}
